# Google Gemini API — 用於生成 AI 命盤報告
GEMINI_API_KEY=AIza...

# 使用的模型（預設 Gemini 2.5 Flash）
# GEMINI_MODEL=gemini-2.5-flash

# 部署用 base URL（產生分享連結用）
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 子路徑部署用：若要掛在 https://futurestarai.com/original-face/ 底下，設定此值
# 本機 dev 留空即可
# BASE_PATH=/original-face

# （日後想切回 Claude，安裝 @anthropic-ai/sdk 並把 ai-report.ts 換回即可）
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-6
