# Anthropic API — 用於生成 AI 命盤報告
ANTHROPIC_API_KEY=sk-ant-...

# 使用的模型（預設 Sonnet 4.6，高品質報告可改 Opus 4.6）
ANTHROPIC_MODEL=claude-sonnet-4-6

# （選擇性）提示快取 beta header，默認自動啟用
# ANTHROPIC_BETA=prompt-caching-2024-07-31

# 部署用 base URL（產生分享連結用）
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 子路徑部署用：若要掛在 https://futurestarai.com/original-face/ 底下，設定此值
# 本機 dev 留空即可
# BASE_PATH=/original-face
